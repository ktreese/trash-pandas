# ─────────────────────────────────────────────
# Trash Pandas 14U — environment variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# Neon Postgres (free tier at https://neon.tech)
# Create a project, copy the "pooled connection" string
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# Vercel Blob (from vercel.com → Storage → Blob → your store → .env.local tab)
# OR run: vercel env pull .env.local  (after linking with `vercel link`)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"
