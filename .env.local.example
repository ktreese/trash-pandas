# ─────────────────────────────────────────────────────────────
# Trash Pandas 14U — environment variables
# Copy this file to .env.local and fill in values.
# Run `node scripts/setup-admin.mjs` to generate the admin vars.
# ─────────────────────────────────────────────────────────────

# Vercel Blob (run `vercel env pull .env.local` to auto-populate)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# ── Admin dashboard ───────────────────────────────────────────
# Generated by: node scripts/setup-admin.mjs
ADMIN_PASSWORD_HASH=""        # bcrypt hash of your admin password
ADMIN_TOTP_SECRET=""          # TOTP secret (scan with Duo Mobile / Google Auth)
ADMIN_JWT_SECRET=""           # Random 32-byte hex string for signing admin sessions

# ── Upload protection ─────────────────────────────────────────
UPLOAD_JWT_SECRET=""          # Random 32-byte hex string for signing upload cookies
TEAM_UPLOAD_CODE=""           # Passphrase shared with parents via GameChanger
